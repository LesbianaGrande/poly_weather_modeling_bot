# ── Paper Trading ──────────────────────────────────────────────────────────────
# Starting paper bankroll in dollars
STARTING_BANKROLL=1000.0

# Path to SQLite database file
# On Railway: mount a volume at /data and set this to /data/paper_trades.db
DB_PATH=./paper_trades.db

# ── Kelly / Bet Sizing ─────────────────────────────────────────────────────────
# Kelly multiplier. 0.25 = quarter-Kelly (recommended). Range: 0.0–1.0
KELLY_FRACTION=0.25

# Minimum edge (our_prob - market_prob) required to open a position
# 0.03 = we only bet if our probability exceeds the market by at least 3 points
MIN_EDGE=0.03

# Maximum fraction of bankroll to risk on any single trade
MAX_POSITION_FRACTION=0.10

# Minimum dollar amount for a trade to be opened (skip tiny Kelly bets)
MIN_TRADE_DOLLARS=1.0

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often to run a full market scan (hours). 6 aligns with GFS model runs (00Z/06Z/12Z/18Z)
SCAN_INTERVAL_HOURS=6

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG shows all API calls and math details. INFO is quieter for production.
LOG_LEVEL=DEBUG
